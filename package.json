    "@aws-sdk/client-bedrock-agentcore-control": "^3.800.0",
    "@aws-sdk/client-bedrock-runtime": "^3.800.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1039.0",
    "@babel/runtime": "^7.29.2",
    "@cloudscape-design/components": "^3.0.1286",
    "@cloudscape-design/design-tokens": "^3.0.84",
    "@cloudscape-design/global-styles": "^1.0.58",
    "@fastify/cors": "^11.0.0",
    "bedrock-agentcore": "^0.2.2",
    "fastify": "^5.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
