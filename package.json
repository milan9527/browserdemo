{
  "name": "agentcore-browser-demo",
  "version": "1.0.0",
  "description": "Demo platform showcasing AgentCore Browser tool with DCV Live View — web crawling, user login, and persistent sessions",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
